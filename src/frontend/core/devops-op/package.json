{
  "name": "devops-op",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "public": "vite build",
    "public:dev": "cross-env dist=frontend lsVersion=dev vite build",
    "public:test": "cross-env dist=frontend lsVersion=dev vite build",
    "public:master": "cross-env dist=frontend lsVersion=dev vite build && node rename-after-build.js",
    "public:external": "cross-env dist=frontend lsVersion=dev vite build",
    "build:prod": "vite build",
    "build:stage": "vite build --mode staging",
    "preview": "vite preview",
    "svgo": "svgo -f src/icons/svg --config=src/icons/svgo.yml",
    "lint": "eslint --ext .js,.vue src",
    "test:unit": "jest --clearCache",
    "test:ci": "npm run lint && npm run test:unit"
  },
  "dependencies": {
    "axios": "1.12.0",
    "core-js": "^3.48.0",
    "element-ui": "2.15.14",
    "js-cookie": "2.2.0",
    "js-yaml": "^4.1.0",
    "jsencrypt": "^3.2.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.3",
    "monaco-editor": "^0.52.2",
    "normalize.css": "7.0.0",
    "nprogress": "0.2.0",
    "path-browserify": "^1.0.1",
    "path-to-regexp": "8.0.0",
    "vue": "^2.7.16",
    "vue-router": "3.0.6",
    "vuex": "3.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue2": "^2.3.4",
    "@vitejs/plugin-vue2-jsx": "^1.1.1",
    "vite": "^5.4.0",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-monaco-editor": "^1.1.0",
    "autoprefixer": "9.5.1",
    "eslint-plugin-vue": "^9.28.0",
    "svgo": "3.3.3",
    "tasksfile": "^5.1.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ],
  "engines": {
    "node": ">=8.9",
    "npm": ">= 3.0.0"
  }
}
